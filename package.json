{
  "name": "real-time-chat-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "vite --config vite.frontend.mts --port 5180",
    "build:frontend": "vite build --config vite.frontend.mts",
    "dev:worker": "wrangler dev",
    "build:worker": "vite build --config vite.config.mts",
    "release": "npm run clean && npm run build:worker && wrangler deploy",
    "migrate:new": "drizzle-kit generate",
    "migrate:dev": "wrangler d1 migrations apply DB --local",
    "migrate:prod": "wrangler d1 migrations apply DB --remote",
    "seed": "npm run worker:run ./src/db/seed.ts",
    "clean": "npm run clean:vite",
    "clean:vite": "Remove-Item -Recurse -Force node_modules/.vite -ErrorAction SilentlyContinue",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "dev:init": "rw-scripts dev-init"
  }
}
