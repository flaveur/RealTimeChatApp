/**
 * worker.tsx - Cloudflare Worker Backend API
 * 
 * Implementert med GitHub Copilot
 * 
 * Dette er hovedfilen for backend API-et som kjører på Cloudflare Workers.
 * Den håndterer alle HTTP-forespørsler til applikasjonen inkludert autentisering,
 * brukerdata, venner, meldinger, notater og innstillinger.
 * 
 * Funksjoner:
 * - Autentisering med cookie-baserte sessions (SHA-256 hashing)
 * - CRUD-operasjoner for venner, meldinger, notater
 * - Avatar-opplasting til R2 storage
 * - Automatisk status-håndtering (online/offline/away)
 * - Serving av statiske filer fra /dist mappen
 */

import { eq, or, and, desc } from "drizzle-orm";
import { createDB } from "./db/client";
import { sessions, users, friends, messages, notes } from "./db/schema";

// ----------------------------------------------------------
// Environment-variabler fra Cloudflare Workers
// ----------------------------------------------------------
export interface Env {
  DB: D1Database;        // D1 SQLite database (lokal eller Cloudflare)
  ASSETS: Fetcher;       // Statiske filer fra /dist mappen
  R2?: R2Bucket;        // R2 bucket for avatar-lagring (valgfri)
  VERBOSE?: string;      // Debug-logging (settes i wrangler.toml)
}

// ----------------------------------------------------------
// TypeScript interfaces for request bodies
// ----------------------------------------------------------

// Body for /api/register - Ny brukerregistrering
interface RegisterBody {
  username: string;
  email: string;
  password: string;
}

export default {
  async fetch(request: Request, env: Env) {
    const url = new URL(request.url);
    const db = createDB(env);  // Oppretter Drizzle ORM database-instans
    const VERBOSE = env.VERBOSE === "true";

    // ----------------------------------------------------------
    // Ignorer unødvendige requests
    // Copilot: Disse endepunktene brukes av nettlesere for metadata
    // ----------------------------------------------------------
    if (url.pathname === "/favicon.ico" || url.pathname.startsWith("/.well-known")) {
      return new Response(null, { status: 204 });
    }

    // ----------------------------------------------------------
    // API ENDPOINT: Oppdater brukernavn (visningsnavn)
    // POST /api/me/name
    // Copilot: Lar innlogget bruker endre sitt visningsnavn
    // ----------------------------------------------------------
    if (url.pathname === "/api/me/name" && request.method === "POST") {
      try {
        // Hent session-token fra cookie
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        // Valider session mot database
        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;

        // Valider input
        const { name } = (await request.json()) as { name?: string };
        const next = (name ?? "").trim();
        if (!next) return Response.json({ error: "Navn kan ikke være tomt" }, { status: 400 });
        if (next.length < 2) return Response.json({ error: "Navn må være minst 2 tegn" }, { status: 400 });

        // Sjekk at brukernavn ikke er tatt av andre brukere
        const existing = await db.select().from(users).where(eq(users.username, next)).all();
        if (existing.some((u: any) => (u.id ?? u.ID) !== (sess.userId ?? sess.user_id))) {
          return Response.json({ error: "Brukernavnet er allerede tatt" }, { status: 409 });
        }

        // Oppdater brukernavnet i databasen
        await db.update(users).set({ username: next }).where(eq(users.id, sess.userId ?? sess.user_id));

        return Response.json({ success: true, name: next });
      } catch (err) {
        console.error("/api/me/name error:", err);
        return Response.json({ error: "Kunne ikke oppdatere navn", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // API ENDPOINT: Last opp/oppdater avatar-bilde
    // POST /api/me/avatar
    // Copilot: Håndterer profilbilde-opplasting til R2 storage
    // ----------------------------------------------------------
    if (url.pathname === "/api/me/avatar" && request.method === "POST") {
      try {
        // Autentiser bruker via session-cookie
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        // Valider session
        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;

        // Parse multipart/form-data for fil-opplasting
        const form = await request.formData();
        const file = form.get("avatar");
        if (!file || typeof file === "string") {
          return Response.json({ error: "Mangler avatar-fil" }, { status: 400 });
        }

        // Valider filstørrelse (maks 2MB)
        const ct = (file as File).type || "application/octet-stream";
        const size = (file as File).size || 0;
        if (size > 2 * 1024 * 1024) {
          return Response.json({ error: "Bildet er for stort (maks 2MB)" }, { status: 413 });
        }

        const userId = sess.userId ?? sess.user_id;
        const key = `avatars/${userId}`;  // R2 storage key

        if (env.R2) {
          // Last opp til R2 bucket med riktig content-type
          await env.R2.put(key, (file as File).stream(), { httpMetadata: { contentType: ct } });
          const urlPath = `/api/avatar/${userId}?v=${Date.now()}`; // cache-busting query param
          await db.update(users).set({ avatarUrl: urlPath }).where(eq(users.id, userId));
          return Response.json({ success: true, avatarUrl: urlPath });
        } else {
          // Fallback: lagre som data-URL direkte i DB (kun for lokal utvikling uten R2)
          const arrayBuffer = await (file as File).arrayBuffer();
          const base64 = btoa(String.fromCharCode(...new Uint8Array(arrayBuffer)));
          const dataUrl = `data:${ct};base64,${base64}`;
          await db.update(users).set({ avatarUrl: dataUrl }).where(eq(users.id, userId));
          return Response.json({ success: true, avatarUrl: dataUrl });
        }
      } catch (err) {
        console.error("/api/me/avatar error:", err);
        return Response.json({ error: "Kunne ikke oppdatere avatar", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // API ENDPOINT: Hent avatar fra R2 storage
    // GET /api/avatar/:userId
    // Copilot: Returnerer brukerens profilbilde fra R2 bucket
    // ----------------------------------------------------------
    if (url.pathname.startsWith("/api/avatar/") && request.method === "GET") {
      try {
        const userId = url.pathname.split("/api/avatar/")[1];
        if (!userId) return new Response("Not found", { status: 404 });
        if (!env.R2) return new Response("R2 ikke konfigurert", { status: 501 });
        
        const key = `avatars/${userId}`;
        const obj = await env.R2.get(key);
        if (!obj) return new Response("Not found", { status: 404 });
        
        // Sett riktig content-type og caching headers
        const headers = new Headers();
        const ct = obj.httpMetadata?.contentType || "application/octet-stream";
        headers.set("Content-Type", ct);
        headers.set("Cache-Control", "public, max-age=3600");  // Cache i 1 time
        return new Response(obj.body, { status: 200, headers });
      } catch (err) {
        console.error("/api/avatar error:", err);
        return new Response("Internal error", { status: 500 });
      }
    }

    // ==================================================================
    // AUTENTISERING - Registrering og Innlogging
    // ==================================================================

    // ----------------------------------------------------------
    // API ENDPOINT: Registrer ny bruker
    // POST /api/register
    // Copilot: Oppretter ny brukerkonto med SHA-256 password hashing
    // Merk: Logger IKKE inn automatisk - bruker må logge inn manuelt etterpå
    // ----------------------------------------------------------
    if (url.pathname === "/api/register" && request.method === "POST") {
      try {
        const { username, email, password } = (await request.json()) as RegisterBody;

        // Valider at alle felt er utfylt
        if (!username || !email || !password) {
          return Response.json({ error: "Alle felt må fylles ut" }, { status: 400 });
        }

        // Sjekk at e-posten ikke allerede er i bruk
        const existingEmail = await db.select().from(users).where(eq(users.email, email)).all();
        if (existingEmail.length > 0) {
          return Response.json({ error: "E-post er allerede registrert" }, { status: 409 });
        }

        // Sjekk at brukernavn ikke allerede er i bruk
        const existingUsername = await db.select().from(users).where(eq(users.username, username)).all();
        if (existingUsername.length > 0) {
          return Response.json({ error: "Brukernavnet er allerede tatt" }, { status: 409 });
        }

        // Hash passord med SHA-256 (Web Crypto API)
        // Sikrer at passord aldri lagres i klartekst
        const encoder = new TextEncoder();
        const pwBuffer = encoder.encode(password);
        const digest = await crypto.subtle.digest("SHA-256", pwBuffer);
        const hashed = Array.from(new Uint8Array(digest))
          .map((b) => b.toString(16).padStart(2, "0"))  // Konverter til hex-string
          .join("");

        // Lagre ny bruker i databasen med offline status som default
        await db.insert(users).values({
          id: crypto.randomUUID(),  // Generer unik UUID for bruker
          username,
          email,
          password: hashed,         // Lagrer hashet passord (SHA-256)
          status: "offline",        // Ny bruker starter som offline
        });

        if (VERBOSE) console.log("Ny bruker registrert:", username);
        // Returnerer success uten å logge inn automatisk
        return Response.json({ success: true }, { status: 201 });
      } catch (err) {
        console.error("Feil under registrering:", err);
        return Response.json(
          { error: "Brukernavn eller e-post er allerede i bruk", details: String(err) },
          { status: 500 }
        );
      }
    }

    // ----------------------------------------------------------
    // API ENDPOINT: Login
    // POST /api/login
    // Copilot: Autentiserer bruker og oppretter session med HttpOnly cookie
    // ----------------------------------------------------------
    if (url.pathname === "/api/login" && request.method === "POST") {
      try {
        const { username, password } = (await request.json()) as any;
        if (!username || !password) {
          return Response.json({ error: "Mangler brukernavn eller passord" }, { status: 400 });
        }

        // Hent bruker fra database basert på brukernavn
        const found = await db.select().from(users).where(eq(users.username, username)).all();
        if (!found || found.length === 0) {
          return Response.json({ error: "Ugyldig brukernavn eller passord" }, { status: 401 });
        }

        const user = found[0] as any;

        // Hash innsendt passord for å sammenligne med lagret hash
        const encoder = new TextEncoder();
        const pwBuffer = encoder.encode(password);
        const digest = await crypto.subtle.digest("SHA-256", pwBuffer);
        const hashed = Array.from(new Uint8Array(digest))
          .map((b) => b.toString(16).padStart(2, "0"))
          .join("");

        // Sjekk om hashet passord matcher lagret passord
        if (hashed !== user.password) {
          return Response.json({ error: "Ugyldig brukernavn eller passord" }, { status: 401 });
        }

        // Opprett ny session-token (UUID) for autentisering
        const token = crypto.randomUUID();
        await db.insert(sessions).values({ id: crypto.randomUUID(), userId: user.id, token });

        // Returner session-token som HttpOnly cookie for sikkerhet
        // HttpOnly: JavaScript kan ikke lese cookien (beskyttelse mot XSS)
        // SameSite=Lax: Beskyttelse mot CSRF-angrep
        const cookie = `session=${token}; Path=/; HttpOnly; SameSite=Lax`;
        return Response.json({ success: true }, { status: 200, headers: { "Set-Cookie": cookie } });
      } catch (err) {
        console.error("Login error:", err);
        return Response.json({ error: "Innlogging feilet", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // API ENDPOINT: Hent innlogget bruker
    // GET /api/me
    // Copilot: Returnerer informasjon om den påloggede brukeren
    // ----------------------------------------------------------
    if (url.pathname === "/api/me" && request.method === "GET") {
      try {
        // Parse session-token fra cookie header
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        // Valider at session finnes i database
        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;

        // Hent brukerdata fra database
        const u = await db.select().from(users).where(eq(users.id, sess.userId ?? sess.user_id)).all();
        if (!u || u.length === 0) return Response.json({ error: "Bruker ikke funnet" }, { status: 404 });
        const user = u[0] as any;

        // Returner brukerobjekt til frontend (uten passord!)
        return Response.json({
          user: {
            id: user.id,
            username: user.username,
            name: user.username, // frontend bruker 'name' som displayName
            avatarUrl: user.avatar_url ?? user.avatarUrl,
            status: user.status ?? "offline",
          },
        });
      } catch (err) {
        console.error("/api/me error:", err);
        return Response.json({ error: "Kunne ikke hente bruker", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // API ENDPOINT: Oppdater brukerstatus
    // POST /api/me/status
    // Copilot: Lar bruker sette sin status (online/busy/away)
    // ----------------------------------------------------------
    if (url.pathname === "/api/me/status" && request.method === "POST") {
      try {
        // Autentiser bruker via session-cookie
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        // Valider session
        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;

        // Les og valider status fra request body
        const { status } = (await request.json()) as { status: "online" | "busy" | "away" };
        if (!status || !["online", "busy", "away"].includes(status)) {
          return Response.json({ error: "Ugyldig status" }, { status: 400 });
        }

        // Oppdater status i database for innlogget bruker
        await db.update(users).set({ status }).where(eq(users.id, sess.userId ?? sess.user_id));

        if (VERBOSE) console.log("Status oppdatert:", sess.userId ?? sess.user_id, "->", status);
        return Response.json({ success: true, status });
      } catch (err) {
        console.error("/api/me/status error:", err);
        return Response.json({ error: "Kunne ikke oppdatere status", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // API ENDPOINT: Logg ut
    // POST /api/logout
    // Copilot: Sletter session og setter bruker til offline automatisk
    // ----------------------------------------------------------
    if (url.pathname === "/api/logout" && request.method === "POST") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;

        if (token) {
          // Hent bruker-ID før vi sletter session
          const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
          if (s && s.length > 0) {
            const sess = s[0] as any;
            const userId = sess.userId ?? sess.user_id;
            
            // Sett bruker til offline automatisk ved logout
            await db.update(users).set({ status: "offline" }).where(eq(users.id, userId));
          }
          
          // Slett session fra database
          await db.delete(sessions).where(eq(sessions.token, token));
        }

        const expired = `session=; Path=/; HttpOnly; Max-Age=0; SameSite=Lax`;
        return Response.json({ success: true }, { status: 200, headers: { "Set-Cookie": expired } });
      } catch (err) {
        console.error("Logout-feil:", err);
        return Response.json({ error: "Kunne ikke logge ut", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // FRIENDS API
    // ----------------------------------------------------------

    // Hent alle venner
    if (url.pathname === "/api/friends" && request.method === "GET") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        // Hent alle vennskap hvor brukeren er involvert
        const allFriendships = await db
          .select()
          .from(friends)
          .where(or(eq(friends.userId, userId), eq(friends.friendId, userId)))
          .all();

        // Hent detaljer om alle vennene
        const friendships = await Promise.all(
          allFriendships.map(async (f: any) => {
            const friendId = f.userId === userId ? f.friendId : f.userId;
            const friendData = await db.select().from(users).where(eq(users.id, friendId)).all();
            const friend = friendData[0] as any;

            return {
              id: f.id,
              userId: f.userId,
              friendId: f.friendId,
              status: f.status,
              createdAt: f.createdAt,
              friend: friend
                ? {
                    id: friend.id,
                    username: friend.username,
                    name: friend.username,
                    avatarUrl: friend.avatar_url ?? friend.avatarUrl,
                    status: friend.status ?? "offline",
                  }
                : null,
            };
          })
        );

        return Response.json({ friends: friendships });
      } catch (err) {
        console.error("/api/friends error:", err);
        return Response.json({ error: "Kunne ikke hente venner", details: String(err) }, { status: 500 });
      }
    }

    // Søk etter brukere
    if (url.pathname === "/api/users/search" && request.method === "GET") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const query = url.searchParams.get("q") || "";
        if (query.length < 2) {
          return Response.json({ users: [] });
        }

        // Søk etter brukere (case-insensitive via LIKE)
        const allUsers = await db.select().from(users).all();
        const results = allUsers.filter(
          (u: any) =>
            u.username.toLowerCase().includes(query.toLowerCase()) && u.id !== userId
        );

        const usersData = results.map((u: any) => ({
          id: u.id,
          username: u.username,
          name: u.username,
          avatarUrl: u.avatar_url ?? u.avatarUrl,
          status: u.status ?? "offline",
        }));

        return Response.json({ users: usersData });
      } catch (err) {
        console.error("/api/users/search error:", err);
        return Response.json({ error: "Søk feilet", details: String(err) }, { status: 500 });
      }
    }

    // Send venneforespørsel
    if (url.pathname === "/api/friends/request" && request.method === "POST") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const { friendId } = (await request.json()) as { friendId: string };
        if (!friendId) {
          return Response.json({ error: "Mangler friendId" }, { status: 400 });
        }

        // Sjekk at vennskap ikke allerede eksisterer
        const existing = await db
          .select()
          .from(friends)
          .where(
            or(
              and(eq(friends.userId, userId), eq(friends.friendId, friendId)),
              and(eq(friends.userId, friendId), eq(friends.friendId, userId))
            )
          )
          .all();

        if (existing.length > 0) {
          return Response.json({ error: "Venneforespørsel eksisterer allerede" }, { status: 409 });
        }

        // Opprett venneforespørsel
        await db.insert(friends).values({
          id: crypto.randomUUID(),
          userId,
          friendId,
          status: "pending",
        });

        return Response.json({ success: true });
      } catch (err) {
        console.error("/api/friends/request error:", err);
        return Response.json({ error: "Kunne ikke sende forespørsel", details: String(err) }, { status: 500 });
      }
    }

    // Aksepter venneforespørsel
    if (url.pathname === "/api/friends/accept" && request.method === "POST") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });

        const { friendshipId } = (await request.json()) as { friendshipId: string };
        if (!friendshipId) {
          return Response.json({ error: "Mangler friendshipId" }, { status: 400 });
        }

        // Oppdater status til "accepted"
        await db.update(friends).set({ status: "accepted" }).where(eq(friends.id, friendshipId));

        return Response.json({ success: true });
      } catch (err) {
        console.error("/api/friends/accept error:", err);
        return Response.json({ error: "Kunne ikke akseptere forespørsel", details: String(err) }, { status: 500 });
      }
    }

    // Fjern venn
    if (url.pathname === "/api/friends/remove" && request.method === "DELETE") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });

        const { friendshipId } = (await request.json()) as { friendshipId: string };
        if (!friendshipId) {
          return Response.json({ error: "Mangler friendshipId" }, { status: 400 });
        }

        // Slett vennskap
        await db.delete(friends).where(eq(friends.id, friendshipId));

        return Response.json({ success: true });
      } catch (err) {
        console.error("/api/friends/remove error:", err);
        return Response.json({ error: "Kunne ikke fjerne venn", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // NOTES API
    // ----------------------------------------------------------

    // Hent alle notater for innlogget bruker
    if (url.pathname === "/api/notes" && request.method === "GET") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const userNotes = await db
          .select()
          .from(notes)
          .where(eq(notes.userId, userId))
          .orderBy(desc(notes.createdAt))
          .all();

        return Response.json({ notes: userNotes });
      } catch (err) {
        console.error("/api/notes GET error:", err);
        return Response.json({ error: "Kunne ikke hente notater", details: String(err) }, { status: 500 });
      }
    }

    // Opprett nytt notat
    if (url.pathname === "/api/notes" && request.method === "POST") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const { title, content } = (await request.json()) as { title: string; content?: string };
        if (!title || !title.trim()) {
          return Response.json({ error: "Tittel er påkrevd" }, { status: 400 });
        }

        const newNote = {
          id: crypto.randomUUID(),
          userId,
          title: title.trim(),
          content: content?.trim() || "",
          createdAt: new Date().toISOString(),
        };

        await db.insert(notes).values(newNote);

        return Response.json({ note: newNote }, { status: 201 });
      } catch (err) {
        console.error("/api/notes POST error:", err);
        return Response.json({ error: "Kunne ikke opprette notat", details: String(err) }, { status: 500 });
      }
    }

    // Oppdater notat
    if (url.pathname.startsWith("/api/notes/") && request.method === "PUT") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const noteId = url.pathname.split("/api/notes/")[1];
        if (!noteId) {
          return Response.json({ error: "Mangler notat-ID" }, { status: 400 });
        }

        const { title, content } = (await request.json()) as { title?: string; content?: string };

        // Sjekk at notatet tilhører brukeren
        const existing = await db.select().from(notes).where(eq(notes.id, noteId)).all();
        if (!existing || existing.length === 0) {
          return Response.json({ error: "Notat ikke funnet" }, { status: 404 });
        }
        const note = existing[0] as any;
        if (note.userId !== userId) {
          return Response.json({ error: "Ikke autorisert" }, { status: 403 });
        }

        await db
          .update(notes)
          .set({
            title: title?.trim() || note.title,
            content: content?.trim() || note.content,
            updatedAt: new Date().toISOString(),
          })
          .where(eq(notes.id, noteId));

        return Response.json({ success: true });
      } catch (err) {
        console.error("/api/notes PUT error:", err);
        return Response.json({ error: "Kunne ikke oppdatere notat", details: String(err) }, { status: 500 });
      }
    }

    // Slett notat
    if (url.pathname.startsWith("/api/notes/") && request.method === "DELETE") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const noteId = url.pathname.split("/api/notes/")[1];
        if (!noteId) {
          return Response.json({ error: "Mangler notat-ID" }, { status: 400 });
        }

        // Sjekk at notatet tilhører brukeren
        const existing = await db.select().from(notes).where(eq(notes.id, noteId)).all();
        if (!existing || existing.length === 0) {
          return Response.json({ error: "Notat ikke funnet" }, { status: 404 });
        }
        const note = existing[0] as any;
        if (note.userId !== userId) {
          return Response.json({ error: "Ikke autorisert" }, { status: 403 });
        }

        await db.delete(notes).where(eq(notes.id, noteId));

        return Response.json({ success: true });
      } catch (err) {
        console.error("/api/notes DELETE error:", err);
        return Response.json({ error: "Kunne ikke slette notat", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // MESSAGES/THREADS API
    // ----------------------------------------------------------

    // Hent tråder (basert på aksepterte venner)
    if (url.pathname === "/api/threads" && request.method === "GET") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        // Hent alle aksepterte venner
        const acceptedFriends = await db
          .select()
          .from(friends)
          .where(
            and(
              or(eq(friends.userId, userId), eq(friends.friendId, userId)),
              eq(friends.status, "accepted")
            )
          )
          .all();

        // Hent detaljer om hver venn og siste melding
        const threads = await Promise.all(
          acceptedFriends.map(async (f: any) => {
            const friendId = f.userId === userId ? f.friendId : f.userId;
            const friendData = await db.select().from(users).where(eq(users.id, friendId)).all();
            const friend = friendData[0] as any;

            // Hent siste melding
            const lastMsg = await db
              .select()
              .from(messages)
              .where(
                or(
                  and(eq(messages.senderId, userId), eq(messages.receiverId, friendId)),
                  and(eq(messages.senderId, friendId), eq(messages.receiverId, userId))
                )
              )
              .orderBy(desc(messages.createdAt))
              .limit(1)
              .all();

            return {
              id: f.id, // friendshipId brukes som threadId
              title: friend?.username || "Ukjent",
              lastMessage: lastMsg[0] ? (lastMsg[0] as any).content : null,
              avatarUrl: friend?.avatar_url ?? friend?.avatarUrl,
            };
          })
        );

        return Response.json({ threads });
      } catch (err) {
        console.error("/api/threads error:", err);
        return Response.json({ error: "Kunne ikke hente tråder", details: String(err) }, { status: 500 });
      }
    }

    // Hent meldinger for en tråd
    if (url.pathname === "/api/messages" && request.method === "GET") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const threadId = url.searchParams.get("threadId"); // threadId er friendshipId
        if (!threadId) {
          return Response.json({ error: "Mangler threadId" }, { status: 400 });
        }

        // Hent vennskapet
        const friendship = await db.select().from(friends).where(eq(friends.id, threadId)).all();
        if (!friendship || friendship.length === 0) {
          return Response.json({ error: "Tråd ikke funnet" }, { status: 404 });
        }
        const f = friendship[0] as any;
        const friendId = f.userId === userId ? f.friendId : f.userId;

        // Hent alle meldinger mellom brukerne
        const msgs = await db
          .select()
          .from(messages)
          .where(
            or(
              and(eq(messages.senderId, userId), eq(messages.receiverId, friendId)),
              and(eq(messages.senderId, friendId), eq(messages.receiverId, userId))
            )
          )
          .orderBy(messages.createdAt)
          .all();

        // Hent brukerinfo for begge parter
        const [currentUser, friendUser] = await Promise.all([
          db.select().from(users).where(eq(users.id, userId)).all(),
          db.select().from(users).where(eq(users.id, friendId)).all(),
        ]);

        const userMap: Record<string, any> = {
          [userId]: currentUser[0],
          [friendId]: friendUser[0],
        };

        const formattedMessages = msgs.map((m: any) => {
          const author = userMap[m.senderId];
          return {
            id: m.id,
            authorId: m.senderId,
            text: m.content,
            createdAt: m.createdAt,
            authorName: author?.username || "Ukjent",
            authorAvatar: author?.avatar_url ?? author?.avatarUrl,
          };
        });

        return Response.json({ messages: formattedMessages });
      } catch (err) {
        console.error("/api/messages GET error:", err);
        return Response.json({ error: "Kunne ikke hente meldinger", details: String(err) }, { status: 500 });
      }
    }

    // Send melding
    if (url.pathname === "/api/messages" && request.method === "POST") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const { threadId, text } = (await request.json()) as { threadId: string; text: string };
        if (!threadId || !text?.trim()) {
          return Response.json({ error: "Mangler threadId eller text" }, { status: 400 });
        }

        // Hent vennskapet
        const friendship = await db.select().from(friends).where(eq(friends.id, threadId)).all();
        if (!friendship || friendship.length === 0) {
          return Response.json({ error: "Tråd ikke funnet" }, { status: 404 });
        }
        const f = friendship[0] as any;
        const receiverId = f.userId === userId ? f.friendId : f.userId;

        // Opprett melding
        const newMessage = {
          id: crypto.randomUUID(),
          senderId: userId,
          receiverId,
          content: text.trim(),
          friendshipId: threadId,
          createdAt: new Date().toISOString(),
        };

        await db.insert(messages).values(newMessage);

        return Response.json({ success: true, message: newMessage }, { status: 201 });
      } catch (err) {
        console.error("/api/messages POST error:", err);
        return Response.json({ error: "Kunne ikke sende melding", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // USER SETTINGS API
    // ----------------------------------------------------------

    // Hent brukerinnstillinger
    if (url.pathname === "/api/me/settings" && request.method === "GET") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const u = await db.select().from(users).where(eq(users.id, userId)).all();
        if (!u || u.length === 0) return Response.json({ error: "Bruker ikke funnet" }, { status: 404 });
        const user = u[0] as any;

        const settings = user.settings ? JSON.parse(user.settings) : {};

        return Response.json({ settings });
      } catch (err) {
        console.error("/api/me/settings GET error:", err);
        return Response.json({ error: "Kunne ikke hente innstillinger", details: String(err) }, { status: 500 });
      }
    }

    // Oppdater brukerinnstillinger
    if (url.pathname === "/api/me/settings" && request.method === "PUT") {
      try {
        const cookie = request.headers.get("cookie") || "";
        const match = cookie.match(/(?:^|;)\s*session=([^;]+)/);
        const token = match ? match[1] : null;
        if (!token) return Response.json({ error: "Ikke autentisert" }, { status: 401 });

        const s = await db.select().from(sessions).where(eq(sessions.token, token)).all();
        if (!s || s.length === 0) return Response.json({ error: "Ugyldig session" }, { status: 401 });
        const sess = s[0] as any;
        const userId = sess.userId ?? sess.user_id;

        const newSettings = (await request.json()) as any;

        await db
          .update(users)
          .set({ settings: JSON.stringify(newSettings) })
          .where(eq(users.id, userId));

        return Response.json({ success: true, settings: newSettings });
      } catch (err) {
        console.error("/api/me/settings PUT error:", err);
        return Response.json({ error: "Kunne ikke oppdatere innstillinger", details: String(err) }, { status: 500 });
      }
    }

    // Test databaseforbindelse
    if (url.pathname === "/api/test-db" && request.method === "GET") {
      try {
        const allUsers = await db.select().from(users).all();
        return Response.json({ success: true, users: allUsers });
      } catch (err) {
        console.error("Feil i test-db:", err);
        return Response.json({ error: "Databasefeil", details: String(err) }, { status: 500 });
      }
    }

    // Slett bruker (kun for test)
    if (url.pathname === "/api/delete-user" && request.method === "DELETE") {
      try {
        const id = url.searchParams.get("id");
        if (!id) {
          return Response.json({ error: "Mangler bruker-ID" }, { status: 400 });
        }

        await db.delete(users).where(eq(users.id, id));
        return Response.json({ success: true });
      } catch (err) {
        console.error("Feil under sletting:", err);
        return Response.json({ error: "Databasefeil", details: String(err) }, { status: 500 });
      }
    }

    // ----------------------------------------------------------
    // FRONTEND (React build fra ASSETS)
    // Copilot: Serverer statiske filer fra /dist mappen
    // ----------------------------------------------------------
    // Kun server statiske filer for GET-requests
    if (request.method === "GET") {
      try {
        let assetResponse = await env.ASSETS.fetch(request);

        // Hvis fila ikke finnes → server index.html (SPA fallback for React Router)
        if (assetResponse.status === 404) {
          const indexReq = new Request(`${url.origin}/index.html`, {
            method: "GET",
            headers: request.headers,
          });
          assetResponse = await env.ASSETS.fetch(indexReq);
        }

        // Fix: Sett riktig Content-Type basert på filendelse
        // Copilot: Cloudflare ASSETS kan noen ganger returnere feil MIME type
        if (assetResponse.status === 200) {
          const newHeaders = new Headers(assetResponse.headers);
          
          // Sjekk filendelse og sett riktig Content-Type
          if (url.pathname.endsWith('.js')) {
            newHeaders.set('Content-Type', 'application/javascript; charset=utf-8');
          } else if (url.pathname.endsWith('.css')) {
            newHeaders.set('Content-Type', 'text/css; charset=utf-8');
          } else if (url.pathname.endsWith('.html')) {
            newHeaders.set('Content-Type', 'text/html; charset=utf-8');
          } else if (url.pathname.endsWith('.json')) {
            newHeaders.set('Content-Type', 'application/json; charset=utf-8');
          } else if (url.pathname.endsWith('.png')) {
            newHeaders.set('Content-Type', 'image/png');
          } else if (url.pathname.endsWith('.jpg') || url.pathname.endsWith('.jpeg')) {
            newHeaders.set('Content-Type', 'image/jpeg');
          } else if (url.pathname.endsWith('.svg')) {
            newHeaders.set('Content-Type', 'image/svg+xml');
          } else if (url.pathname.endsWith('.ico')) {
            newHeaders.set('Content-Type', 'image/x-icon');
          }

          return new Response(assetResponse.body, {
            status: assetResponse.status,
            statusText: assetResponse.statusText,
            headers: newHeaders,
          });
        }

        return assetResponse;
      } catch (err) {
        console.error("ASSETS fetch error:", err);
        return new Response("Feil under lasting av frontend", { status: 500 });
      }
    }

    // Hvis vi kommer hit, er det en ukjent request
    return new Response("Not found", { status: 404 });
  },
};

// Fjernet toppnivå debug-fetch: relative fetch kall ved modul-load kan føre til oppstartsfeil i wrangler.